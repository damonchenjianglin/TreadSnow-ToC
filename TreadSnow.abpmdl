      "folder": "src"
    },
    "TreadSnow.Application.Contracts": {
      "path": "src/TreadSnow.Application.Contracts/TreadSnow.Application.Contracts.abppkg",
      "folder": "src"
    },
    "TreadSnow.HttpApi": {
      "path": "src/TreadSnow.HttpApi/TreadSnow.HttpApi.abppkg",
      "folder": "src"
    },
    "TreadSnow.HttpApi.Client": {
      "path": "src/TreadSnow.HttpApi.Client/TreadSnow.HttpApi.Client.abppkg",
      "folder": "src"
    },
    "TreadSnow.EntityFrameworkCore.Tests": {
