      "folder": "test"
    },
    "TreadSnow.DbMigrator": {
      "path": "src/TreadSnow.DbMigrator/TreadSnow.DbMigrator.abppkg",
      "folder": "src"
    },
    "TreadSnow.HttpApi.Host": {
